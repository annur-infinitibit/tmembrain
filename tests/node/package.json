{
  "name": "membrain-tests",
  "version": "1.0.0",
  "description": "Test suite for Membrain Node.js bindings",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:basic": "jest test_basic_usage.test.js",
    "test:graph": "jest test_graph_memory.test.js"
