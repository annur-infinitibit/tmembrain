    "memory",
    "llm",
    "testing"
  ],
  "author": "",
  "devDependencies": {
    "dotenv": "^16.3.1",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "membrain": "file:../../membrain-node",
    "openai": "^4.104.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ],
    "verbose": true
  }
}
